# --- MongoDB (required) ---
# Option A: Local MongoDB (must be running on port 27017)
#   Windows: net start MongoDB   (Administrator shell)
#   macOS/Linux: sudo systemctl start mongod
MONGODB_URI=mongodb://localhost:27017/crop-yield-predictor

# Option B: MongoDB Atlas (free M0 cluster — use for cloud/deploy)
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/crop-yield-predictor?retryWrites=true&w=majority

# Auth
JWT_SECRET=your-long-random-secret

# External APIs
GEMINI_API_KEY=your-gemini-api-key
WEATHER_API_KEY=your-openweathermap-api-key

# Python ML service — local dev: run Python on port 5000 (Node uses 8000)
# Production (Render): set to your crop-yield-ml service URL
PYTHON_YIELD_URL=http://localhost:5000/v1/predict/yield-production
PYTHON_DISEASE_URL=http://localhost:5000/v1/detect/pest-disease

# Render sets PORT automatically
PORT=8000
